# SlopMachine secrets — COPY to `.env` (which is git-ignored) and fill in.
# `.env` is loaded by `uv run --env-file .env ...` (or set UV_ENV_FILE=.env once in your shell
# profile so a plain `uv run` picks it up). uv reads dotenv natively — no python-dotenv dependency.
# Real process env vars take precedence over values here. Tokens are NEVER committed.

# --- Remote provider tokens (only used when SLOP_ALLOW_CLOUD is on) -------------------------------
# Google Gemini image API key (Gemini Developer API). Create at https://aistudio.google.com/apikey
# (or the Cloud console). The key must allow the "Generative Language API" service.
GEMINI_API_KEY=

# Hugging Face token for Inference Providers. Two options:
#   1) Paste a fine-grained token (https://huggingface.co/settings/tokens) with the
#      "Make calls to Inference Providers" permission — durable, recommended for .env.
#   2) Leave blank and instead export it at runtime from your CLI login:
#      $env:HF_TOKEN = (uvx hf auth token)      # the login token auto-refreshes
HF_TOKEN=

# --- Cloud spend gate ----------------------------------------------------------------------------
# OFF by default on purpose: remote providers cost money. Uncomment to opt in to paid cloud calls.
# Leaving it commented keeps the gate a deliberate, per-session choice.
# SLOP_ALLOW_CLOUD=1
